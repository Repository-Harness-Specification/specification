{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repository-harness-specification.github.io/schema/0.2/harness.schema.json",
  "title": "Repository Harness Manifest",
  "description": "Draft 0.2 schema for .harness/harness.yaml",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "repository",
    "entrypoint",
    "routing",
    "documents",
    "commands",
    "routes"
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]*$"
    },
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {
          "not": {
            "pattern": "^/"
          }
        },
        {
          "not": {
            "pattern": "^[A-Za-z]:"
          }
        },
        {
          "not": {
            "pattern": "\\\\"
          }
        },
        {
          "not": {
            "pattern": "(^|/)\\.\\.(/|$)"
          }
        }
      ]
    },
    "matchSet": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "any": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "all": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "oneOf": [
        {
          "required": [
            "any"
          ]
        },
        {
          "required": [
            "all"
          ]
        }
      ]
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "concerns": {
          "$ref": "#/$defs/matchSet"
        },
        "paths": {
          "$ref": "#/$defs/matchSet"
        },
        "scopes": {
          "$ref": "#/$defs/matchSet"
        }
      }
    },
    "conditionalDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document",
        "when"
      ],
      "properties": {
        "document": {
          "$ref": "#/$defs/identifier"
        },
        "when": {
          "$ref": "#/$defs/selector"
        }
      }
    },
    "conditionalCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "when"
      ],
      "properties": {
        "command": {
          "$ref": "#/$defs/identifier"
        },
        "when": {
          "$ref": "#/$defs/selector"
        }
      }
    },
    "contextSelection": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "conditional": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/conditionalDocument"
          }
        }
      }
    },
    "validationSelection": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "conditional": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/conditionalCommand"
          }
        }
      }
    }
  },
  "properties": {
    "spec": {
      "const": "repository-harness/0.2"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "entrypoint": {
      "$ref": "#/$defs/repositoryPath"
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "on_no_match"
      ],
      "properties": {
        "strategy": {
          "const": "first-match"
        },
        "on_no_match": {
          "enum": [
            "report",
            "ask"
          ]
        }
      }
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "purpose"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/identifier"
          },
          "path": {
            "$ref": "#/$defs/repositoryPath"
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "paths"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/identifier"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "paths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/repositoryPath"
            }
          }
        }
      }
    },
    "concerns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/identifier"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "signals": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "run",
          "description"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/identifier"
          },
          "run": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "working_directory": {
            "$ref": "#/$defs/repositoryPath"
          },
          "mutates": {
            "type": "boolean"
          },
          "requires_approval": {
            "type": "boolean"
          },
          "availability": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "on_unavailable"
            ],
            "properties": {
              "executables": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "platforms": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "enum": [
                    "linux",
                    "macos",
                    "windows"
                  ]
                }
              },
              "environment_variables": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                }
              },
              "on_unavailable": {
                "enum": [
                  "report",
                  "fail"
                ]
              }
            },
            "anyOf": [
              {
                "required": [
                  "executables"
                ]
              },
              {
                "required": [
                  "platforms"
                ]
              },
              {
                "required": [
                  "environment_variables"
                ]
              }
            ]
          }
        }
      }
    },
    "validation_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "match",
          "commands"
        ],
        "properties": {
          "match": {
            "$ref": "#/$defs/selector"
          },
          "commands": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/identifier"
            }
          }
        }
      }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "match"
        ],
        "anyOf": [
          {
            "required": [
              "context"
            ]
          },
          {
            "required": [
              "validation"
            ]
          }
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/identifier"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "match": {
            "$ref": "#/$defs/selector"
          },
          "context": {
            "$ref": "#/$defs/contextSelection"
          },
          "validation": {
            "$ref": "#/$defs/validationSelection"
          }
        }
      }
    },
    "extensions": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9.-]+$"
      },
      "additionalProperties": true
    }
  }
}
