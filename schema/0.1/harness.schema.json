{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repository-harness-specification.github.io/schema/harness.schema.json",
  "title": "Repository Harness Manifest",
  "description": "Draft 0.1 schema for .harness/harness.yaml",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "repository",
    "entrypoint",
    "documents",
    "commands",
    "routes"
  ],
  "properties": {
    "spec": {
      "const": "repository-harness/0.1"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "purpose",
          "load_when"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._-]*$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "load_when": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "run",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._-]*$"
          },
          "run": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "mutates": {
            "type": "boolean",
            "default": false
          },
          "requires_approval": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "load",
          "validate"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "load": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validate": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9.-]+$"
      },
      "additionalProperties": true
    }
  }
}
